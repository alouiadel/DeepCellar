# Copy to `.env` and fill in values. Never commit `.env`.

# Provider: ollama | ai_grid | openai
DEFAULT_MODEL_PROVIDER=ai_grid

# AI Grid / any OpenAI-compatible gateway
AI_GRID_API_KEY=
AI_GRID_BASE_URL=http://app.ai-grid.io:4000/v1
DEFAULT_MODEL_LABEL=google/gemma-4-31B

# Optional aliases
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama (local) — in Docker use host.docker.internal
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_HOST=http://host.docker.internal:11434

# Database
# Local default (no Docker): SQLite under DATA_DIR
# DATABASE_URL=sqlite:///./deepcellar.db
# Docker Compose sets DATABASE_URL to Postgres automatically.
POSTGRES_USER=deepcellar
POSTGRES_PASSWORD=deepcellar
POSTGRES_DB=deepcellar
POSTGRES_PORT=5432

# Compose published ports
FRONTEND_PORT=8080
BACKEND_PORT=8000

# Persist backend secret key
# DATA_DIR=/data
