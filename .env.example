# Copy to `.env` and fill in values. Never commit `.env`.

# Provider: ollama | ai_grid | openai
DEFAULT_MODEL_PROVIDER=ai_grid

# AI Grid / any OpenAI-compatible gateway
AI_GRID_API_KEY=
AI_GRID_BASE_URL=http://app.ai-grid.io:4000/v1
DEFAULT_MODEL_LABEL=google/gemma-4-31B

# Optional aliases (same as AI_GRID_* when using openai provider)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama (when DEFAULT_MODEL_PROVIDER=ollama)
# OLLAMA_HOST=http://localhost:11434
